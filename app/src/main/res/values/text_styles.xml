<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base Text style to allow implicit inheritance -->
    <style name="Text" />

    <!-- Typography scale (8 levels) -->
    <style name="Text.Display">
        <item name="android:textSize">@dimen/text_display</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">-0.02</item>
        <item name="android:lineSpacingMultiplier">1.1</item>
    </style>

    <style name="Text.H1">
        <item name="android:textSize">@dimen/text_h1</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">-0.01</item>
    </style>

    <style name="Text.H2">
        <item name="android:textSize">@dimen/text_h2</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="Text.H3">
        <item name="android:textSize">@dimen/text_h3</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="Text.BodyLarge">
        <item name="android:textSize">@dimen/text_body_lg</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:lineSpacingMultiplier">1.4</item>
    </style>

    <style name="Text.Body">
        <item name="android:textSize">@dimen/text_body</item>
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:lineSpacingMultiplier">1.4</item>
    </style>

    <style name="Text.Caption">
        <item name="android:textSize">@dimen/text_caption</item>
        <item name="android:textColor">@color/text_tertiary</item>
    </style>

    <style name="Text.Label">
        <item name="android:textSize">@dimen/text_label</item>
        <item name="android:textColor">@color/text_tertiary</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:letterSpacing">0.08</item>
    </style>
</resources>
