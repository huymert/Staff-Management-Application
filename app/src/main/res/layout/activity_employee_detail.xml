<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/employeeDetailsRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:animateLayoutChanges="true"
    android:background="#F2F7FA"
    android:fitsSystemWindows="true">

    <FrameLayout
        android:id="@+id/headerBackground"
        android:layout_width="0dp"
        android:layout_height="178dp"
        android:animation="@anim/fade_slide_down"
        android:background="@drawable/bg_header_attendance_report"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <View
            android:layout_width="220dp"
            android:layout_height="220dp"
            android:layout_gravity="start|top"
            android:layout_marginStart="-88dp"
            android:layout_marginTop="8dp"
            android:alpha="0.22"
            android:background="@drawable/bg_texture_circle" />

        <View
            android:layout_width="145dp"
            android:layout_height="145dp"
            android:layout_gravity="end|bottom"
            android:layout_marginEnd="-52dp"
            android:layout_marginBottom="8dp"
            android:alpha="0.18"
            android:background="@drawable/bg_texture_circle" />

        <LinearLayout
            android:id="@+id/headerContent"
            android:layout_width="match_parent"
            android:layout_height="82dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingEnd="16dp">

            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:padding="10dp"
                android:src="@android:drawable/ic_menu_revert"
                app:tint="@android:color/white" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="14dp"
                android:layout_weight="1"
                android:text="@string/employee_details_title"
                android:textColor="@android:color/white"
                android:textSize="20sp"
                android:textStyle="bold" />
        </LinearLayout>
    </FrameLayout>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/avatarCard"
        android:layout_width="108dp"
        android:layout_height="108dp"
        android:layout_marginTop="96dp"
        android:animation="@anim/button_pop"
        app:cardBackgroundColor="#FAF7FF"
        app:cardCornerRadius="54dp"
        app:cardElevation="2dp"
        app:strokeColor="#FFFFFF"
        app:strokeWidth="3dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/ivAvatar"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="4dp"
            android:scaleType="centerCrop"
            android:src="@android:drawable/ic_menu_report_image"
            app:shapeAppearanceOverlay="@style/CircleImage" />
    </com.google.android.material.card.MaterialCardView>

    <androidx.core.widget.NestedScrollView
        android:id="@+id/detailsScrollView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:animation="@anim/fade_slide_up"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:overScrollMode="never"
        android:paddingStart="18dp"
        android:paddingEnd="18dp"
        android:paddingBottom="18dp"
        app:layout_constraintBottom_toTopOf="@id/layoutButtons"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/avatarCard">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/detailsCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:layout_marginBottom="18dp"
            app:cardBackgroundColor="#FAF7FF"
            app:cardCornerRadius="28dp"
            app:cardElevation="2dp"
            app:strokeColor="#E4F7FB"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:animateLayoutChanges="true"
                android:orientation="vertical"
                android:paddingStart="18dp"
                android:paddingTop="22dp"
                android:paddingEnd="18dp"
                android:paddingBottom="20dp">

                <TextView
                    android:id="@+id/tvFullName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="@string/full_name_hint"
                    android:textColor="#12313A"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvRolePosition"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="20dp"
                    android:gravity="center"
                    android:text="@string/position_hint"
                    android:textColor="#6F9CAB"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginBottom="16dp"
                    android:background="#D8F8FC" />

                <include
                    android:id="@+id/detailEmail"
                    layout="@layout/item_detail_info" />

                <include
                    android:id="@+id/detailPhone"
                    layout="@layout/item_detail_info" />

                <include
                    android:id="@+id/detailBirthDate"
                    layout="@layout/item_detail_info" />

                <include
                    android:id="@+id/detailJoinDate"
                    layout="@layout/item_detail_info" />

                <include
                    android:id="@+id/detailGender"
                    layout="@layout/item_detail_info" />

                <include
                    android:id="@+id/detailDepartment"
                    layout="@layout/item_detail_info" />

                <include
                    android:id="@+id/detailAddress"
                    layout="@layout/item_detail_info" />

                <include
                    android:id="@+id/detailEmployeeCode"
                    layout="@layout/item_detail_info" />

                <include
                    android:id="@+id/detailCitizenId"
                    layout="@layout/item_detail_info" />

                <include
                    android:id="@+id/detailEmergencyName"
                    layout="@layout/item_detail_info" />

                <include
                    android:id="@+id/detailEmergencyPhone"
                    layout="@layout/item_detail_info" />

                <include
                    android:id="@+id/detailSalary"
                    layout="@layout/item_detail_info" />

                <include
                    android:id="@+id/detailStatus"
                    layout="@layout/item_detail_info" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </androidx.core.widget.NestedScrollView>

    <LinearLayout
        android:id="@+id/layoutButtons"
        android:layout_width="0dp"
        android:layout_height="92dp"
        android:animation="@anim/fade_slide_up"
        android:background="@android:color/white"
        android:elevation="8dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="18dp"
        android:paddingTop="12dp"
        android:paddingEnd="18dp"
        android:paddingBottom="18dp"
        android:weightSum="2"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDelete"
            style="@style/Button.Secondary"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_marginEnd="8dp"
            android:layout_weight="1"
            android:text="@string/delete_staff_title"
            android:textColor="@color/error"
            app:strokeColor="@color/error" />


        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnEdit"
            style="@style/Button.Primary"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:text="@string/update_staff_info" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>