<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/managerDashboardRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:animateLayoutChanges="true"
    android:background="#F2F7FA">

    <androidx.core.widget.NestedScrollView
        android:id="@+id/mainContent"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:animation="@anim/fade_slide_up"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:overScrollMode="never"
        android:paddingBottom="24dp"
        app:layout_constraintBottom_toTopOf="@id/footerContainer"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:id="@+id/contentWrapper"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:animateLayoutChanges="true"
            android:orientation="vertical">

            <FrameLayout
                android:id="@+id/headerBackground"
                android:layout_width="match_parent"
                android:layout_height="180dp"
                android:animation="@anim/fade_slide_down"
                android:background="@drawable/bg_header_attendance_report">

                <View
                    android:layout_width="230dp"
                    android:layout_height="230dp"
                    android:layout_gravity="start|top"
                    android:layout_marginStart="-95dp"
                    android:layout_marginTop="10dp"
                    android:alpha="0.22"
                    android:background="@drawable/bg_texture_circle" />

                <View
                    android:layout_width="145dp"
                    android:layout_height="145dp"
                    android:layout_gravity="end|bottom"
                    android:layout_marginEnd="-55dp"
                    android:layout_marginBottom="16dp"
                    android:alpha="0.18"
                    android:background="@drawable/bg_texture_circle" />

                <LinearLayout
                    android:id="@+id/headerLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="18dp"
                    android:paddingTop="20dp"
                    android:paddingEnd="18dp"
                    android:paddingBottom="10dp">

                    <com.google.android.material.imageview.ShapeableImageView
                        android:id="@+id/ivUserAvatar"
                        android:layout_width="68dp"
                        android:layout_height="68dp"
                        android:background="#26FFFFFF"
                        android:padding="4dp"
                        android:scaleType="centerCrop"
                        android:src="@android:drawable/ic_menu_gallery"
                        app:shapeAppearanceOverlay="@style/RoundedImage"
                        app:strokeColor="@android:color/white"
                        app:strokeWidth="2dp" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="13dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvUserName"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:ellipsize="end"
                            android:maxLines="1"
                            android:text="@string/manager_name_placeholder"
                            android:textColor="@android:color/white"
                            android:textSize="20sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvUserEmail"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="3dp"
                            android:ellipsize="end"
                            android:maxLines="1"
                            android:text="@string/manager_email_placeholder"
                            android:textColor="#EAFBFF"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/dateContainer"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            app:cardBackgroundColor="#33FFFFFF"
                            app:cardCornerRadius="18dp"
                            app:cardElevation="0dp"
                            app:strokeColor="#66FFFFFF"
                            app:strokeWidth="1dp">

                            <TextView
                                android:id="@+id/tvCurrentDate"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:letterSpacing="0.02"
                                android:paddingStart="14dp"
                                android:paddingTop="6dp"
                                android:paddingEnd="14dp"
                                android:paddingBottom="6dp"
                                android:text="@string/current_date_placeholder"
                                android:textColor="@android:color/white"
                                android:textSize="13sp"
                                android:textStyle="bold" />
                        </com.google.android.material.card.MaterialCardView>
                    </LinearLayout>

                    <ImageButton
                        android:id="@+id/btnSettings"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:padding="10dp"
                        android:src="@android:drawable/ic_menu_manage"
                        app:tint="@android:color/white" />

                    <ImageButton
                        android:id="@+id/btnLogout"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:layout_marginStart="4dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:padding="10dp"
                        android:src="@android:drawable/ic_lock_power_off"
                        app:tint="@android:color/white" />
                </LinearLayout>
            </FrameLayout>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/checkInPanel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="18dp"
                android:layout_marginTop="-48dp"
                android:layout_marginEnd="18dp"
                android:animation="@anim/fade_slide_up"
                app:cardBackgroundColor="#FAF7FF"
                app:cardCornerRadius="30dp"
                app:cardElevation="2dp"
                app:strokeColor="#E4F7FB"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:animateLayoutChanges="true"
                    android:gravity="center_horizontal"
                    android:orientation="vertical"
                    android:paddingStart="18dp"
                    android:paddingTop="22dp"
                    android:paddingEnd="18dp"
                    android:paddingBottom="20dp">

                    <TextView
                        android:id="@+id/tvWorkDurationLabel"
                        style="@style/Text.Label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/working_time"
                        android:textColor="#6F9CAB"
                        android:visibility="gone" />

                    <TextView
                        android:id="@+id/tvTimer"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="monospace"
                        android:text="00:00:00"
                        android:textColor="#12313A"
                        android:textSize="40sp"
                        android:textStyle="bold"
                        android:visibility="gone" />

                    <FrameLayout
                        android:id="@+id/btnMainActionContainer"
                        android:layout_width="190dp"
                        android:layout_height="190dp"
                        android:layout_marginTop="10dp"
                        android:animation="@anim/button_pop">

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:alpha="0.28"
                            android:background="@drawable/bg_check_circle" />

                        <View
                            android:id="@+id/btnMainAction"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@drawable/bg_check_circle"
                            android:clickable="true"
                            android:focusable="true"
                            android:foreground="?attr/selectableItemBackgroundBorderless" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:orientation="vertical">

                            <ImageView
                                android:layout_width="@dimen/icon_lg"
                                android:layout_height="@dimen/icon_lg"
                                android:src="@android:drawable/ic_menu_my_calendar"
                                app:tint="@android:color/white" />

                            <TextView
                                android:id="@+id/tvMainStatus"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/space_xs"
                                android:gravity="center"
                                android:text="@string/check_in"
                                android:textAlignment="center"
                                android:textColor="@android:color/white"
                                android:textSize="26sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/tap_to_start"
                                android:textColor="#EAFBFF"
                                android:textSize="@dimen/text_caption" />
                        </LinearLayout>
                    </FrameLayout>

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/statsCard"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"
                        app:cardBackgroundColor="#FFFFFF"
                        app:cardCornerRadius="22dp"
                        app:cardElevation="0dp"
                        app:strokeColor="#D8F8FC"
                        app:strokeWidth="1dp">

                        <LinearLayout
                            android:id="@+id/statsLayout"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:paddingTop="14dp"
                            android:paddingBottom="14dp">

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:gravity="center"
                                android:orientation="vertical">

                                <TextView
                                    style="@style/Text.Label"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/check_in"
                                    android:textColor="#6F9CAB" />

                                <TextView
                                    android:id="@+id/tvCheckInTime"
                                    style="@style/Text.H3"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="3dp"
                                    android:text="--:--"
                                    android:textColor="#24B5D3" />
                            </LinearLayout>

                            <View
                                android:layout_width="1dp"
                                android:layout_height="42dp"
                                android:background="#D8F8FC" />

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:gravity="center"
                                android:orientation="vertical">

                                <TextView
                                    style="@style/Text.Label"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/check_out"
                                    android:textColor="#6F9CAB" />

                                <TextView
                                    android:id="@+id/tvCheckOutTime"
                                    style="@style/Text.H3"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="3dp"
                                    android:text="--:--"
                                    android:textColor="#24B5D3" />
                            </LinearLayout>

                            <View
                                android:layout_width="1dp"
                                android:layout_height="42dp"
                                android:background="#D8F8FC" />

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:gravity="center"
                                android:orientation="vertical">

                                <TextView
                                    style="@style/Text.Label"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/duration"
                                    android:textColor="#6F9CAB" />

                                <TextView
                                    android:id="@+id/tvTotalHours"
                                    style="@style/Text.H3"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="3dp"
                                    android:text="00h 00m"
                                    android:textColor="#7B61FF" />
                            </LinearLayout>
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnLeaveRequests"
                style="@style/Button.Secondary"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginStart="18dp"
                android:layout_marginTop="16dp"
                android:layout_marginEnd="18dp"
                android:layout_marginBottom="24dp"
                android:animation="@anim/fade_slide_up"
                android:backgroundTint="#FAF7FF"
                android:text="@string/review_leave_requests"
                android:textAllCaps="false"
                android:textColor="#24B5D3"
                android:textStyle="bold"
                app:cornerRadius="28dp"
                app:elevation="2dp"
                app:icon="@android:drawable/ic_menu_my_calendar"
                app:iconTint="#24B5D3"
                app:strokeColor="#D8F8FC"
                app:strokeWidth="1dp" />
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <LinearLayout
        android:id="@+id/footerContainer"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:animation="@anim/fade_slide_up"
        android:background="@android:color/white"
        android:elevation="8dp"
        android:orientation="vertical"
        android:paddingStart="8dp"
        android:paddingTop="6dp"
        android:paddingEnd="8dp"
        android:paddingBottom="4dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <com.google.android.material.bottomnavigation.BottomNavigationView
            android:id="@+id/bottomNavigation"
            android:layout_width="match_parent"
            android:layout_height="100dp"
            android:background="@android:color/transparent"
            android:clipToPadding="false"
            android:paddingBottom="4dp"
            app:elevation="0dp"
            app:itemIconSize="22dp"
            app:itemIconTint="#24B5D3"
            app:itemRippleColor="#3324B5D3"
            app:itemTextColor="#24B5D3"
            app:labelVisibilityMode="labeled"
            app:menu="@menu/manager_bottom_nav_menu" />
    </LinearLayout>

    <FrameLayout
        android:id="@+id/loadingOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#80000000"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone">

        <ProgressBar
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:indeterminateTint="@color/white" />
    </FrameLayout>

</androidx.constraintlayout.widget.ConstraintLayout>