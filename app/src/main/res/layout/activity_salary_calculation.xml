<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/salaryCalculationRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:animateLayoutChanges="true"
    android:background="#F2F7FA">

    <FrameLayout
        android:id="@+id/headerBackground"
        android:layout_width="0dp"
        android:layout_height="156dp"
        android:animation="@anim/fade_slide_down"
        android:background="@drawable/bg_header_attendance_report"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <View
            android:layout_width="220dp"
            android:layout_height="220dp"
            android:layout_gravity="start|top"
            android:layout_marginStart="-90dp"
            android:layout_marginTop="8dp"
            android:alpha="0.22"
            android:background="@drawable/bg_texture_circle" />

        <View
            android:layout_width="145dp"
            android:layout_height="145dp"
            android:layout_gravity="end|bottom"
            android:layout_marginEnd="-52dp"
            android:layout_marginBottom="0dp"
            android:alpha="0.18"
            android:background="@drawable/bg_texture_circle" />

        <LinearLayout
            android:id="@+id/headerContent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingTop="10dp"
            android:paddingEnd="16dp"
            android:paddingBottom="10dp">

            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:padding="10dp"
                android:src="@drawable/ic_back_arrow"
                app:tint="@android:color/white" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="14dp"
                android:layout_weight="1"
                android:text="Tính lương tháng"
                android:textColor="@android:color/white"
                android:textSize="21sp"
                android:textStyle="bold" />
        </LinearLayout>
    </FrameLayout>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/monthPickerCard"
        android:layout_width="0dp"
        android:layout_height="72dp"
        android:layout_marginStart="18dp"
        android:layout_marginTop="-25dp"
        android:layout_marginEnd="18dp"
        android:animation="@anim/fade_slide_up"
        app:cardBackgroundColor="#FAF7FF"
        app:cardCornerRadius="26dp"
        app:cardElevation="2dp"
        app:strokeColor="#E4F7FB"
        app:strokeWidth="1dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/headerBackground">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="12dp"
            android:paddingEnd="12dp">

            <ImageButton
                android:id="@+id/btnPrevMonth"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:padding="10dp"
                android:src="@android:drawable/ic_media_previous"
                app:tint="#24B5D3" />

            <TextView
                android:id="@+id/tvMonthYear"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="Tháng 4/2026"
                android:textColor="#12313A"
                android:textSize="18sp"
                android:textStyle="bold" />

            <ImageButton
                android:id="@+id/btnNextMonth"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:padding="10dp"
                android:src="@android:drawable/ic_media_next"
                app:tint="#24B5D3" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/formulaCard"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="18dp"
        android:layout_marginTop="14dp"
        android:layout_marginEnd="18dp"
        android:animation="@anim/fade_slide_up"
        app:cardBackgroundColor="#FFFFFF"
        app:cardCornerRadius="18dp"
        app:cardElevation="0dp"
        app:strokeColor="#D8F8FC"
        app:strokeWidth="1dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/monthPickerCard">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="14dp"
            android:paddingTop="10dp"
            android:paddingEnd="14dp"
            android:paddingBottom="10dp"
            android:text="Công thức: Lương = LươngCB × (Ngày_đi_làm/26) × (1 + Điểm_NS/100 × 0.2)"
            android:textColor="#6F9CAB"
            android:textSize="12sp"
            android:textStyle="bold" />
    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/salaryListCard"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="18dp"
        android:layout_marginTop="12dp"
        android:layout_marginEnd="18dp"
        android:layout_marginBottom="18dp"
        android:animation="@anim/fade_slide_up"
        app:cardBackgroundColor="#FAF7FF"
        app:cardCornerRadius="28dp"
        app:cardElevation="2dp"
        app:strokeColor="#E4F7FB"
        app:strokeWidth="1dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/formulaCard">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvSalary"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:overScrollMode="never"
            android:padding="12dp" />
    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>