<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/myTasksRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:animateLayoutChanges="true"
    android:background="#F2F7FA"
    android:fitsSystemWindows="true">

    <FrameLayout
        android:id="@+id/headerLayout"
        android:layout_width="0dp"
        android:layout_height="142dp"
        android:animation="@anim/fade_slide_down"
        android:background="@drawable/bg_header_attendance_report"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <View
            android:layout_width="220dp"
            android:layout_height="220dp"
            android:layout_gravity="start|top"
            android:layout_marginStart="-90dp"
            android:layout_marginTop="8dp"
            android:alpha="0.22"
            android:background="@drawable/bg_texture_circle" />

        <View
            android:layout_width="145dp"
            android:layout_height="145dp"
            android:layout_gravity="end|bottom"
            android:layout_marginEnd="-52dp"
            android:alpha="0.18"
            android:background="@drawable/bg_texture_circle" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="92dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingEnd="18dp">

            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:padding="10dp"
                android:src="@android:drawable/ic_menu_revert"
                app:tint="@android:color/white" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="14dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:text="@string/my_tasks_title"
                    android:textColor="@android:color/white"
                    android:textSize="21sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:text="@string/task_hint_tap_complete"
                    android:textColor="#EAFBFF"
                    android:textSize="13sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>
    </FrameLayout>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/taskListCard"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="18dp"
        android:layout_marginTop="-38dp"
        android:layout_marginEnd="18dp"
        android:layout_marginBottom="16dp"
        android:animation="@anim/fade_slide_up"
        app:cardBackgroundColor="#FAF7FF"
        app:cardCornerRadius="28dp"
        app:cardElevation="2dp"
        app:strokeColor="#E4F7FB"
        app:strokeWidth="1dp"
        app:layout_constraintBottom_toTopOf="@id/footerContainer"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/headerLayout">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvTasks"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:overScrollMode="never"
            android:padding="12dp"
            android:paddingBottom="96dp" />
    </com.google.android.material.card.MaterialCardView>

    <LinearLayout
        android:id="@+id/footerContainer"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:animation="@anim/fade_slide_up"
        android:background="@android:color/white"
        android:elevation="8dp"
        android:orientation="vertical"
        android:paddingStart="8dp"
        android:paddingTop="6dp"
        android:paddingEnd="8dp"
        android:paddingBottom="12dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <com.google.android.material.bottomnavigation.BottomNavigationView
            android:id="@+id/bottomNavigation"
            android:layout_width="match_parent"
            android:layout_height="100dp"
            android:background="@android:color/transparent"
            android:clipToPadding="false"
            android:paddingBottom="4dp"
            app:elevation="0dp"
            app:itemIconSize="22dp"
            app:itemIconTint="#24B5D3"
            app:itemRippleColor="#3324B5D3"
            app:itemTextColor="#24B5D3"
            app:labelVisibilityMode="labeled"
            app:menu="@menu/employee_bottom_nav_menu" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>