<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:animateLayoutChanges="true"
    android:background="#F2F7FA"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:paddingStart="18dp"
    android:paddingTop="22dp"
    android:paddingEnd="18dp"
    android:paddingBottom="22dp">

    <com.google.android.material.card.MaterialCardView
        android:layout_width="276dp"
        android:layout_height="276dp"
        android:layout_marginBottom="24dp"
        android:animation="@anim/button_pop"
        app:cardBackgroundColor="#FAF7FF"
        app:cardCornerRadius="138dp"
        app:cardElevation="2dp"
        app:strokeColor="#D8F8FC"
        app:strokeWidth="3dp">

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/ivZoomedImage"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="7dp"
            android:scaleType="centerCrop"
            android:src="@android:drawable/ic_menu_gallery"
            app:shapeAppearanceOverlay="@style/CircleImage" />
    </com.google.android.material.card.MaterialCardView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:animation="@anim/fade_slide_up"
        android:orientation="horizontal"
        android:weightSum="2">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnGallery"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="54dp"
            android:layout_marginEnd="7dp"
            android:layout_weight="1"
            android:text="Gallery"
            android:textAllCaps="false"
            android:textColor="#24B5D3"
            android:textStyle="bold"
            app:cornerRadius="27dp"
            app:elevation="0dp"
            app:icon="@android:drawable/ic_menu_gallery"
            app:iconTint="#24B5D3"
            app:strokeColor="#24B5D3"
            app:strokeWidth="1dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCamera"
            android:layout_width="0dp"
            android:layout_height="54dp"
            android:layout_marginStart="7dp"
            android:layout_weight="1"
            android:animation="@anim/button_pop"
            android:background="@drawable/bg_login_button_premium"
            android:text="Camera"
            android:textAllCaps="false"
            android:textColor="@android:color/white"
            android:textStyle="bold"
            app:backgroundTint="@null"
            app:cornerRadius="27dp"
            app:elevation="2dp"
            app:icon="@android:drawable/ic_menu_camera"
            app:iconTint="@android:color/white" />
    </LinearLayout>

</LinearLayout>