<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- ============ BUTTONS ============ -->

    <style name="Button.Primary" parent="Widget.MaterialComponents.Button">
        <item name="android:layout_height">@dimen/button_height</item>
        <item name="android:textSize">@dimen/text_body_lg</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:letterSpacing">0</item>
        <item name="cornerRadius">@dimen/radius_md</item>
        <item name="backgroundTint">@color/brand_primary</item>
        <item name="android:textColor">@color/text_on_primary</item>
        <item name="rippleColor">#33FFFFFF</item>
        <item name="elevation">0dp</item>
    </style>

    <style name="Button.Secondary" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:layout_height">@dimen/button_height</item>
        <item name="android:textSize">@dimen/text_body_lg</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textAllCaps">false</item>
        <item name="cornerRadius">@dimen/radius_md</item>
        <item name="android:textColor">@color/brand_primary</item>
        <item name="strokeColor">@color/outline</item>
        <item name="strokeWidth">1dp</item>
    </style>


    <!-- ============ CARDS ============ -->

    <style name="Card.Default" parent="Widget.MaterialComponents.CardView">
        <item name="cardCornerRadius">@dimen/radius_lg</item>
        <item name="cardElevation">@dimen/elevation_1</item>
        <item name="cardBackgroundColor">@color/surface</item>
        <item name="contentPadding">@dimen/card_padding</item>
        <item name="strokeColor">@color/outline_subtle</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <style name="Card.Action" parent="Card.Default">
        <item name="android:foreground">?attr/selectableItemBackground</item>
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
    </style>

    <!-- ============ INPUT FIELDS ============ -->

    <style name="Input.Outlined" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxCornerRadiusTopStart">@dimen/radius_md</item>
        <item name="boxCornerRadiusTopEnd">@dimen/radius_md</item>
        <item name="boxCornerRadiusBottomStart">@dimen/radius_md</item>
        <item name="boxCornerRadiusBottomEnd">@dimen/radius_md</item>
        <item name="boxStrokeColor">@color/brand_primary</item>
        <item name="boxStrokeWidth">1dp</item>
        <item name="boxStrokeWidthFocused">2dp</item>
        <item name="hintTextColor">@color/text_secondary</item>
        <item name="android:textColorHint">@color/text_tertiary</item>
    </style>

    <!-- ============ CHIPS / BADGES ============ -->

    <style name="Badge" />

    <style name="Badge.Success">
        <item name="android:textSize">@dimen/text_label</item>
        <item name="android:textColor">@color/success</item>
        <item name="android:background">@drawable/bg_badge_success</item>
        <item name="android:paddingLeft">@dimen/space_xs</item>
        <item name="android:paddingRight">@dimen/space_xs</item>
        <item name="android:paddingTop">4dp</item>
        <item name="android:paddingBottom">4dp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="Badge.Warning">
        <item name="android:textSize">@dimen/text_label</item>
        <item name="android:textColor">@color/warning</item>
        <item name="android:background">@drawable/bg_badge_warning</item>
        <item name="android:paddingLeft">@dimen/space_xs</item>
        <item name="android:paddingRight">@dimen/space_xs</item>
        <item name="android:paddingTop">4dp</item>
        <item name="android:paddingBottom">4dp</item>
        <item name="android:textStyle">bold</item>
    </style>


    <!-- ============ MISC ============ -->

    <style name="Divider" />

    <style name="Divider.Horizontal">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">1dp</item>
        <item name="android:background">@color/divider</item>
    </style>
</resources>
