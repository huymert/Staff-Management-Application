<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_dialog_ocean_rounded">

    <View
        android:id="@+id/viewCircle1"
        android:layout_width="160dp"
        android:layout_height="160dp"
        android:layout_marginStart="-50dp"
        android:layout_marginTop="40dp"
        android:background="@drawable/bg_texture_circle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <View
        android:id="@+id/viewCircle2"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:layout_marginTop="110dp"
        android:layout_marginEnd="-20dp"
        android:background="@drawable/bg_texture_circle"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/passwordCard"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        app:cardBackgroundColor="#F0E9FF"
        app:cardCornerRadius="28dp"
        app:cardElevation="10dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_bias="0.6">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="22dp"
            android:paddingTop="90dp"
            android:paddingEnd="22dp"
            android:paddingBottom="20dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Change Password"
                android:textColor="#12313A"
                android:textSize="22sp"
                android:textStyle="bold"
                android:gravity="center" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Update your password securely"
                android:textColor="#6F9CAB"
                android:textSize="13sp"
                android:gravity="center"
                android:layout_marginTop="4dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginTop="24dp"
                android:background="@drawable/bg_input_ocean"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="16dp"
                android:paddingEnd="16dp">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@android:drawable/ic_lock_idle_lock"
                    app:tint="#27B4D2" />

                <EditText
                    android:id="@+id/etOldPassword"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_marginStart="14dp"
                    android:layout_weight="1"
                    android:background="@android:color/transparent"
                    android:hint="@string/old_password_hint"
                    android:inputType="textPassword"
                    android:padding="0dp"
                    android:singleLine="true"
                    android:textColor="#12313A"
                    android:textColorHint="#6F6680"
                    android:textSize="14sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_input_ocean"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="16dp"
                android:paddingEnd="16dp">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@android:drawable/ic_lock_idle_lock"
                    app:tint="#27B4D2" />

                <EditText
                    android:id="@+id/etNewPassword"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_marginStart="14dp"
                    android:layout_weight="1"
                    android:background="@android:color/transparent"
                    android:hint="@string/new_password_hint"
                    android:inputType="textPassword"
                    android:padding="0dp"
                    android:singleLine="true"
                    android:textColor="#12313A"
                    android:textColorHint="#6F6680"
                    android:textSize="14sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_input_ocean"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="16dp"
                android:paddingEnd="16dp">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@android:drawable/ic_lock_idle_lock"
                    app:tint="#27B4D2" />

                <EditText
                    android:id="@+id/etConfirmPassword"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_marginStart="14dp"
                    android:layout_weight="1"
                    android:background="@android:color/transparent"
                    android:hint="@string/confirm_new_password_hint"
                    android:inputType="textPassword"
                    android:padding="0dp"
                    android:singleLine="true"
                    android:textColor="#12313A"
                    android:textColorHint="#6F6680"
                    android:textSize="14sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:orientation="horizontal"
                android:gravity="end">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnCancel"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/cancel"
                    android:textColor="#6F9CAB"
                    android:minWidth="0dp"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    app:rippleColor="#206F9CAB" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnUpdatePassword"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="@string/change_password_action"
                    android:textColor="@android:color/white"
                    app:backgroundTint="#27B4D2"
                    app:cornerRadius="12dp" />
            </LinearLayout>

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.card.MaterialCardView
        android:layout_width="120dp"
        android:layout_height="120dp"
        app:cardBackgroundColor="#EFE5FF"
        app:cardCornerRadius="60dp"
        app:cardElevation="10dp"
        app:strokeColor="#A7E9F4"
        app:strokeWidth="6dp"
        app:layout_constraintTop_toTopOf="@id/passwordCard"
        app:layout_constraintBottom_toTopOf="@id/passwordCard"
        app:layout_constraintStart_toStartOf="@id/passwordCard"
        app:layout_constraintEnd_toEndOf="@id/passwordCard">

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="30dp"
            android:contentDescription="@string/new_password_hint"
            android:src="@android:drawable/ic_lock_lock"
            app:tint="#27B4D2" />
    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>