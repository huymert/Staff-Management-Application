<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/leaveRequestsRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:animateLayoutChanges="true"
    android:background="#F2F7FA">

    <FrameLayout
        android:id="@+id/headerBackground"
        android:layout_width="0dp"
        android:layout_height="178dp"
        android:animation="@anim/fade_slide_down"
        android:background="@drawable/bg_header_attendance_report"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <View
            android:layout_width="220dp"
            android:layout_height="220dp"
            android:layout_gravity="start|top"
            android:layout_marginStart="-90dp"
            android:layout_marginTop="8dp"
            android:alpha="0.22"
            android:background="@drawable/bg_texture_circle" />

        <View
            android:layout_width="145dp"
            android:layout_height="145dp"
            android:layout_gravity="end|bottom"
            android:layout_marginEnd="-52dp"
            android:layout_marginBottom="8dp"
            android:alpha="0.18"
            android:background="@drawable/bg_texture_circle" />

        <LinearLayout
            android:id="@+id/headerContent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="42dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingTop="10dp"
                android:paddingEnd="16dp">

                <ImageButton
                    android:id="@+id/btnBack"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:padding="10dp"
                    android:src="@android:drawable/ic_menu_revert"
                    app:tint="@android:color/white" />

                <TextView
                    android:id="@+id/tvTitle"
                    style="@style/Text.H3"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="12dp"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:text="@string/leave_requests_title"
                    android:textColor="@android:color/white"
                    android:textStyle="bold" />
            </LinearLayout>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/subtitleContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="72dp"
                android:layout_marginTop="6dp"
                android:layout_marginEnd="18dp"
                app:cardBackgroundColor="#33FFFFFF"
                app:cardCornerRadius="18dp"
                app:cardElevation="0dp"
                app:strokeColor="#66FFFFFF"
                app:strokeWidth="1dp">

                <TextView
                    android:id="@+id/tvSubtitle"
                    style="@style/Text.Body"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingStart="14dp"
                    android:paddingTop="7dp"
                    android:paddingEnd="14dp"
                    android:paddingBottom="7dp"
                    android:text="@string/leave_my_subtitle"
                    android:textColor="@android:color/white"
                    android:textSize="13sp"
                    android:textStyle="bold" />
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
    </FrameLayout>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/summaryGroupCard"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="18dp"
        android:layout_marginTop="-30dp"
        android:layout_marginEnd="18dp"
        android:animation="@anim/fade_slide_up"
        app:cardBackgroundColor="#FAF7FF"
        app:cardCornerRadius="28dp"
        app:cardElevation="2dp"
        app:strokeColor="#E4F7FB"
        app:strokeWidth="1dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/headerBackground">

        <LinearLayout
            android:id="@+id/summaryLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="horizontal"
            android:paddingTop="16dp"
            android:paddingBottom="16dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvTotalRequests"
                    style="@style/Text.H3"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="#24B5D3"
                    android:textStyle="bold" />

                <TextView
                    style="@style/Text.Caption"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:gravity="center"
                    android:text="@string/leave_summary_total"
                    android:textColor="#6F9CAB"
                    android:textStyle="bold" />
            </LinearLayout>

            <View
                android:layout_width="1dp"
                android:layout_height="46dp"
                android:background="#D8F8FC" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvPendingRequests"
                    style="@style/Text.H3"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="#F59E0B"
                    android:textStyle="bold" />

                <TextView
                    style="@style/Text.Caption"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:gravity="center"
                    android:text="@string/leave_summary_pending"
                    android:textColor="#6F9CAB"
                    android:textStyle="bold" />
            </LinearLayout>

            <View
                android:layout_width="1dp"
                android:layout_height="46dp"
                android:background="#D8F8FC" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvApprovedRequests"
                    style="@style/Text.H3"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="#00A86B"
                    android:textStyle="bold" />

                <TextView
                    style="@style/Text.Caption"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:gravity="center"
                    android:text="@string/leave_summary_approved"
                    android:textColor="#6F9CAB"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/tabsCard"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="18dp"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="18dp"
        android:animation="@anim/fade_slide_up"
        app:tabBackground="@drawable/bg_tab"
        app:cardCornerRadius="22dp"
        app:cardElevation="2dp"
        app:strokeColor="#E4F7FB"
        app:strokeWidth="1dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/summaryGroupCard">

        <com.google.android.material.tabs.TabLayout
            android:id="@+id/tabLayoutLeave"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#FAF7FF"
            app:tabBackground="@drawable/bg_tab"
            app:tabIndicatorColor="#24B5D3"
            app:tabIndicatorHeight="3dp"
            app:tabMode="fixed"
            app:tabRippleColor="#3324B5D3"
            app:tabSelectedTextColor="#24B5D3"
            app:tabTextColor="#6F9CAB" />
    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/listCard"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="18dp"
        android:layout_marginTop="12dp"
        android:layout_marginEnd="18dp"
        android:layout_marginBottom="18dp"
        android:animation="@anim/fade_slide_up"
        app:cardBackgroundColor="#FAF7FF"
        app:cardCornerRadius="28dp"
        app:cardElevation="2dp"
        app:strokeColor="#E4F7FB"
        app:strokeWidth="1dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tabsCard">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <TextView
                android:id="@+id/tvEmptyState"
                style="@style/Text.Body"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:gravity="center"
                android:padding="24dp"
                android:text="@string/no_leave_requests"
                android:textColor="#6F9CAB"
                android:textStyle="bold"
                android:visibility="gone" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvLeaveRequests"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clipToPadding="false"
                android:overScrollMode="never"
                android:padding="12dp"
                android:paddingBottom="96dp" />
        </FrameLayout>
    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabAddLeave"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="26dp"
        android:layout_marginBottom="26dp"
        android:animation="@anim/button_pop"
        android:contentDescription="@string/request_leave"
        android:src="@android:drawable/ic_input_add"
        app:backgroundTint="#24B5D3"
        app:elevation="6dp"
        app:layout_constraintBottom_toBottomOf="@id/listCard"
        app:layout_constraintEnd_toEndOf="parent"
        app:tint="@android:color/white" />

</androidx.constraintlayout.widget.ConstraintLayout>