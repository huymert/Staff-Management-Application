<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/rootDashboard"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:animateLayoutChanges="true"
    android:background="#F2F7FA">

    <androidx.core.widget.NestedScrollView
        android:id="@+id/mainContent"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:animation="@anim/fade_slide_up"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:overScrollMode="never"
        android:paddingBottom="18dp"
        app:layout_constraintBottom_toTopOf="@id/footerContainer"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:id="@+id/dashboardContent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:animateLayoutChanges="true"
            android:orientation="vertical">

            <FrameLayout
                android:id="@+id/headerArea"
                android:layout_width="match_parent"
                android:layout_height="180dp"
                android:animation="@anim/fade_slide_down"
                android:background="@drawable/bg_header_attendance_report">

                <View
                    android:id="@+id/bgCircleLeft"
                    android:layout_width="230dp"
                    android:layout_height="230dp"
                    android:layout_gravity="start|top"
                    android:layout_marginStart="-95dp"
                    android:layout_marginTop="10dp"
                    android:alpha="0.22"
                    android:background="@drawable/bg_texture_circle" />

                <View
                    android:id="@+id/bgCircleRight"
                    android:layout_width="145dp"
                    android:layout_height="145dp"
                    android:layout_gravity="end|bottom"
                    android:layout_marginEnd="-55dp"
                    android:layout_marginBottom="16dp"
                    android:alpha="0.18"
                    android:background="@drawable/bg_texture_circle" />

                <LinearLayout
                    android:id="@+id/topHeaderContent"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="18dp"
                    android:paddingTop="20dp"
                    android:paddingEnd="18dp"
                    android:paddingBottom="10dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvCompanyName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/admin_workspace"
                            android:textColor="#EAFBFF"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvGreeting"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="3dp"
                            android:ellipsize="end"
                            android:maxLines="1"
                            android:text="@string/admin_greeting"
                            android:textColor="@android:color/white"
                            android:textSize="23sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <ImageButton
                        android:id="@+id/btnAdminSettings"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:padding="10dp"
                        android:src="@android:drawable/ic_menu_manage"
                        android:transitionName="admin_settings_transition"
                        app:tint="@android:color/white" />

                    <ImageButton
                        android:id="@+id/btnLogout"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:layout_marginStart="8dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:padding="10dp"
                        android:src="@android:drawable/ic_lock_power_off"
                        android:transitionName="logout_transition"
                        app:tint="@android:color/white" />
                </LinearLayout>
            </FrameLayout>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardProfile"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="18dp"
                android:layout_marginTop="-52dp"
                android:layout_marginEnd="18dp"
                android:layout_marginBottom="6dp"
                android:animation="@anim/fade_slide_up"
                android:transitionName="profile_card_transition"
                app:cardBackgroundColor="#FAF7FF"
                app:cardCornerRadius="28dp"
                app:cardElevation="2dp"
                app:rippleColor="#3324B5D3"
                app:strokeColor="#E4F7FB"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="17dp">

                    <com.google.android.material.imageview.ShapeableImageView
                        android:id="@+id/ivAdminAvatar"
                        android:layout_width="58dp"
                        android:layout_height="58dp"
                        android:scaleType="centerCrop"
                        android:src="@drawable/ic_people"
                        app:shapeAppearanceOverlay="@style/RoundedImage"
                        app:strokeColor="#24B5D3"
                        app:strokeWidth="2dp" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="13dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvAdminName"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:ellipsize="end"
                            android:maxLines="1"
                            android:text="@string/admin_name_placeholder"
                            android:textColor="#12313A"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvAdminEmail"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:ellipsize="end"
                            android:maxLines="1"
                            android:text="@string/admin_email_placeholder"
                            android:textColor="#6F9CAB"
                            android:textSize="13sp" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="#DDF8EE"
                        android:paddingStart="11dp"
                        android:paddingTop="6dp"
                        android:paddingEnd="11dp"
                        android:paddingBottom="6dp"
                        android:text="@string/active_status"
                        android:textColor="#00A86B"
                        android:textSize="12sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:id="@+id/sectionTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="18dp"
                android:layout_marginTop="18dp"
                android:layout_marginBottom="8dp"
                android:animation="@anim/fade_slide_up"
                android:text="@string/management_label"
                android:textColor="#12313A"
                android:textSize="19sp"
                android:textStyle="bold" />

            <androidx.gridlayout.widget.GridLayout
                android:id="@+id/actionGrid"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:animateLayoutChanges="true"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingBottom="28dp"
                app:alignmentMode="alignMargins"
                app:columnCount="2"
                app:useDefaultMargins="false">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardAddStaff"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_margin="6dp"
                    android:animation="@anim/fade_slide_up"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    android:transitionName="card_add_staff_transition"
                    app:cardBackgroundColor="#FAF7FF"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="2dp"
                    app:layout_columnWeight="1"
                    app:rippleColor="#3324B5D3"
                    app:strokeColor="#E4F7FB"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <FrameLayout
                            android:layout_width="50dp"
                            android:layout_height="50dp"
                            android:background="@drawable/bg_role_card_admin">

                            <ImageView
                                android:layout_width="25dp"
                                android:layout_height="25dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_people"
                                app:tint="#24B5D3" />
                        </FrameLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="11dp"
                            android:text="@string/nav_employees"
                            android:textColor="#12313A"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="@string/admin_manage_staff"
                            android:textColor="#6F9CAB"
                            android:textSize="12sp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardProductivity"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_margin="6dp"
                    android:animation="@anim/fade_slide_up"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    android:transitionName="card_productivity_transition"
                    app:cardBackgroundColor="#FAF7FF"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="2dp"
                    app:layout_columnWeight="1"
                    app:rippleColor="#337B61FF"
                    app:strokeColor="#EEE7FF"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <FrameLayout
                            android:layout_width="50dp"
                            android:layout_height="50dp"
                            android:background="@drawable/bg_role_card_employee">

                            <ImageView
                                android:layout_width="25dp"
                                android:layout_height="25dp"
                                android:layout_gravity="center"
                                android:src="@android:drawable/ic_menu_edit"
                                app:tint="#7B61FF" />
                        </FrameLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="11dp"
                            android:text="@string/nav_tasks"
                            android:textColor="#12313A"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="@string/admin_manage_tasks"
                            android:textColor="#6F9CAB"
                            android:textSize="12sp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardMonitorStatus"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_margin="6dp"
                    android:animation="@anim/fade_slide_up"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    android:transitionName="card_monitor_status_transition"
                    app:cardBackgroundColor="#FAF7FF"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="2dp"
                    app:layout_columnWeight="1"
                    app:rippleColor="#3300BFA5"
                    app:strokeColor="#E0FAF6"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <FrameLayout
                            android:layout_width="50dp"
                            android:layout_height="50dp"
                            android:background="@drawable/bg_role_card_manager">

                            <ImageView
                                android:layout_width="25dp"
                                android:layout_height="25dp"
                                android:layout_gravity="center"
                                android:src="@android:drawable/ic_menu_my_calendar"
                                app:tint="#00BFA5" />
                        </FrameLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="11dp"
                            android:text="@string/nav_attendance_label"
                            android:textColor="#12313A"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="@string/admin_manage_attendance"
                            android:textColor="#6F9CAB"
                            android:textSize="12sp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardManageSalary"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_margin="6dp"
                    android:animation="@anim/fade_slide_up"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    android:transitionName="card_salary_transition"
                    app:cardBackgroundColor="#FAF7FF"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="2dp"
                    app:layout_columnWeight="1"
                    app:rippleColor="#337B61FF"
                    app:strokeColor="#EEE7FF"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <FrameLayout
                            android:layout_width="50dp"
                            android:layout_height="50dp"
                            android:background="#E8E1FF">

                            <ImageView
                                android:layout_width="25dp"
                                android:layout_height="25dp"
                                android:layout_gravity="center"
                                android:src="@android:drawable/ic_menu_sort_by_size"
                                app:tint="#7B61FF" />
                        </FrameLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="11dp"
                            android:text="@string/nav_salary"
                            android:textColor="#12313A"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="@string/admin_manage_salary"
                            android:textColor="#6F9CAB"
                            android:textSize="12sp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardLeaveRequests"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_margin="6dp"
                    android:animation="@anim/fade_slide_up"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    android:transitionName="card_leave_transition"
                    app:cardBackgroundColor="#FAF7FF"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="2dp"
                    app:layout_columnWeight="1"
                    app:rippleColor="#337B61FF"
                    app:strokeColor="#EEE7FF"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <FrameLayout
                            android:layout_width="50dp"
                            android:layout_height="50dp"
                            android:background="#E8E1FF">

                            <ImageView
                                android:layout_width="25dp"
                                android:layout_height="25dp"
                                android:layout_gravity="center"
                                android:src="@android:drawable/ic_menu_my_calendar"
                                app:tint="#7B61FF" />
                        </FrameLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="11dp"
                            android:text="@string/leave_requests_title"
                            android:textColor="#12313A"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="@string/admin_manage_leave"
                            android:textColor="#6F9CAB"
                            android:textSize="12sp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

            </androidx.gridlayout.widget.GridLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <LinearLayout
        android:id="@+id/footerContainer"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:animation="@anim/fade_slide_up"
        android:background="@android:color/white"
        android:elevation="8dp"
        android:orientation="vertical"
        android:paddingStart="8dp"
        android:paddingTop="6dp"
        android:paddingEnd="8dp"
        android:paddingBottom="4dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <com.google.android.material.bottomnavigation.BottomNavigationView
            android:id="@+id/bottomNavigation"
            android:layout_width="match_parent"
            android:layout_height="100dp"
            android:background="@android:color/transparent"
            android:clipToPadding="false"
            android:paddingBottom="4dp"
            app:elevation="0dp"
            app:itemIconSize="22dp"
            app:itemIconTint="#24B5D3"
            app:itemRippleColor="#3324B5D3"
            app:itemTextColor="#24B5D3"
            app:labelVisibilityMode="labeled"
            app:menu="@menu/admin_bottom_nav_menu" />
    </LinearLayout>

    <FrameLayout
        android:id="@+id/loadingOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/scrim"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone">

        <ProgressBar
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:indeterminateTint="@color/white" />
    </FrameLayout>

</androidx.constraintlayout.widget.ConstraintLayout>