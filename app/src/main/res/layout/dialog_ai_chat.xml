<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingStart="18dp"
    android:paddingTop="18dp"
    android:paddingEnd="18dp"
    android:paddingBottom="18dp"
    android:background="@drawable/bg_white_top_rounded">

    <!-- HANDLE BAR -->
    <View
        android:layout_width="42dp"
        android:layout_height="5dp"
        android:layout_gravity="center"
        android:layout_marginBottom="14dp"
        android:background="#D0DDE4" />

    <!-- TITLE -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="AI Assistant"
        android:textColor="#24B5D3"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_marginBottom="12dp" />

    <!-- RESPONSE BOX -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="200dp"
        android:layout_marginBottom="14dp"
        android:animation="@anim/fade_slide_up"
        app:cardBackgroundColor="#F8FBFD"
        app:cardCornerRadius="18dp"
        app:cardElevation="0dp"
        app:strokeColor="#D8F8FC"
        app:strokeWidth="1dp">

        <androidx.core.widget.NestedScrollView
            android:id="@+id/scrollAiResponse"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true">

            <TextView
                android:id="@+id/tvAiResponse"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="14dp"
                android:text="Chào bạn! Tôi có thể giúp gì cho bạn hôm nay?"
                android:textColor="#12313A"
                android:textSize="15sp"
                android:lineSpacingExtra="3dp" />
        </androidx.core.widget.NestedScrollView>
    </com.google.android.material.card.MaterialCardView>

    <!-- LOADING -->
    <ProgressBar
        android:id="@+id/pbLoading"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_gravity="center"
        android:layout_marginBottom="14dp"
        android:visibility="gone"
        android:indeterminateTint="#24B5D3" />

    <!-- INPUT AREA -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            app:cardBackgroundColor="#FAF7FF"
            app:cardCornerRadius="26dp"
            app:cardElevation="0dp"
            app:strokeColor="#D8F8FC"
            app:strokeWidth="1dp">

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Nhập câu hỏi của bạn..."
                app:boxBackgroundMode="none">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etUserQuery"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:maxLines="3"
                    android:textColor="#12313A"
                    android:textColorHint="#91AAB4"
                    android:paddingStart="16dp"
                    android:paddingTop="10dp"
                    android:paddingEnd="16dp"
                    android:paddingBottom="10dp"
                    android:textSize="14sp"/>
            </com.google.android.material.textfield.TextInputLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- SEND BUTTON -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:layout_marginStart="10dp"
            android:animation="@anim/button_pop"
            app:cardBackgroundColor="#24B5D3"
            app:cardCornerRadius="26dp"
            app:cardElevation="2dp">

            <ImageButton
                android:id="@+id/btnSendQuery"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:padding="14dp"
                android:src="@android:drawable/ic_menu_send"
                app:tint="@android:color/white" />
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>

</LinearLayout>